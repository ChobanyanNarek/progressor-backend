{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testTimeout": 120000,
  "extensionsToTreatAsEsm": [".ts"],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": {
          "verbatimModuleSyntax": false
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.+)\\.ts$": "$1"
  }
}
