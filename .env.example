NODE_ENV=development

#== Secret Manager (production only)
# When NODE_ENV=production the app loads a JSON blob of env vars from Google
# Secret Manager at boot (see src/load-secrets.ts) and merges it into process.env.
# Point this at the secret holding that JSON. Full version resource name, or
# the secret path without the version suffix (`/versions/latest` is assumed).
SECRET_MANAGER_RESOURCE=projects/ghost-app-dev/secrets/DEV_APP_SECRETS

#== APP
PORT=3000
TRANSPORT_PORT=8080
JWT_EXPIRATION_TIME=86400
FALLBACK_LANGUAGE=en_US
ENABLE_ORM_LOGS=true
ENABLE_DOCUMENTATION=true
API_VERSION=v1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=
API_BASE_URL=

#== JWT Auth
# RS256 key pair. Replace with your own keys. Encode newlines as \n on a single line.
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n<your-rsa-private-key>\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n<your-rsa-public-key>\n-----END PUBLIC KEY-----

#== DB
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=awesome_nest_db

#== GCP
# GCP project that owns the GCS bucket.
GCP_PROJECT_ID=your-gcp-project-id
# GCS bucket for uploads. Must use uniform bucket-level access and be made
# public (grant roles/storage.objectViewer to allUsers) so objects are served
# from https://storage.googleapis.com/<bucket>/<key>.
GCS_BUCKET_NAME=your-gcs-bucket-name
# Credentials resolve via Application Default Credentials (ADC). On Cloud Run /
# GKE the attached service account is used automatically. For local dev, point
# this at a service-account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

#== Redis
REDIS_URL=redis://localhost:6379

#== Throttler
THROTTLER_TTL=1m
THROTTLER_LIMIT=10

#== LaoZhang AI (Nano Banana Pro Google Native)
LAOZHANG_API_KEY=sk-YOUR_API_KEY
LAOZHANG_API_BASE_URL=https://api.laozhang.ai

#== KIE AI (Kling AI)
KIE_AI_API_KEY=sk-YOUR_API_KEY

#== Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

#== D-ID
D_ID=your-d-id-api-key
