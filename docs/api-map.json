{
  "info": {
    "title": "Ghost App API Map",
    "globalPrefix": null,
    "totalEndpoints": 22
  },
  "endpoints": [
    {
      "method": "POST",
      "url": "/auth/login",
      "summary": "User info with access token",
      "auth": "@Public",
      "controller": "AuthController",
      "requestDto": {
        "email": "string",
        "password": "string"
      },
      "responseDto": {
        "accessToken": {
          "expiresIn": "number",
          "token": "string"
        }
      }
    },
    {
      "method": "GET",
      "url": "/auth/me",
      "summary": "Current user info",
      "auth": "@Auth([CREATOR, ADMIN])",
      "controller": "AuthController",
      "requestDto": null,
      "responseDto": {
        "firstName": "string",
        "lastName": "string",
        "email": "string",
        "role": "RoleType",
        "avatar?": "string | null"
      }
    },
    {
      "method": "GET",
      "url": "/health",
      "summary": "Health check",
      "auth": "@Public",
      "controller": "HealthCheckerController",
      "requestDto": null,
      "responseDto": {
        "status": "string",
        "info": "Record<string, unknown>",
        "error": "Record<string, unknown>",
        "details": "Record<string, unknown>"
      }
    },
    {
      "method": "POST",
      "url": "/webhooks/did/:secret",
      "summary": "Handle D-ID webhook",
      "auth": "Secret param validation",
      "controller": "DidWebhookController",
      "requestDto": {
        "id": "string",
        "status": "string",
        "result_url?": "string",
        "user_data?": "string",
        "duration?": "number",
        "error?": {
          "kind?": "string",
          "description?": "string"
        }
      },
      "responseDto": {
        "received": "boolean"
      }
    },
    {
      "method": "POST",
      "url": "/internal/ai-generation/process",
      "summary": "Process AI generation task",
      "auth": "@UseGuards(CloudTasksOidcGuard)",
      "controller": "InternalAiGenerationController",
      "requestDto": {
        "talkId": "string"
      },
      "responseDto": {
        "processed": "boolean"
      }
    },
    {
      "method": "GET",
      "url": "/memory-points/nearby",
      "summary": "Get approved memory points near location",
      "auth": "@Public",
      "controller": "MemoryPointController",
      "requestDto": {
        "latitude": "number (-90..90)",
        "longitude": "number (-180..180)",
        "radiusMeters": "number (100..50000, default 5000)",
        "name?": "string",
        "order?": "Order (default ASC)",
        "page?": "number (default 1)",
        "take?": "number (default 10)",
        "q?": "string"
      },
      "responseDto": {
        "data": [
          {
            "id": "Uuid",
            "location": {
              "type": "'Point'",
              "coordinates": "[number, number]"
            }
          }
        ],
        "meta": {
          "page": "number",
          "take": "number",
          "itemCount": "number",
          "pageCount": "number",
          "hasPreviousPage": "boolean",
          "hasNextPage": "boolean"
        }
      }
    },
    {
      "method": "GET",
      "url": "/memory-points/:id",
      "summary": "Get a single approved memory point",
      "auth": "@Public",
      "controller": "MemoryPointController",
      "requestDto": null,
      "responseDto": {
        "id": "Uuid",
        "createdAt": "Date",
        "updatedAt": "Date",
        "location": {
          "type": "'Point'",
          "coordinates": "[number, number]"
        },
        "status": "MemoryPointStatus",
        "userId": "Uuid",
        "memoryPointDetails?": {
          "id": "Uuid",
          "createdAt": "Date",
          "updatedAt": "Date",
          "title?": "string",
          "description?": "string",
          "cloudAnchorId?": "string",
          "videoUrl?": "string (url)",
          "type": "MemoryPointType",
          "sourcePhotoUrl?": "string",
          "sourceAudioUrl?": "string"
        }
      }
    },
